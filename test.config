public static class MetricHelper
{
public static string BuildSelector(List<MetricConfig> metrics)
{
List<string> selectors = new List<string>();

```
    foreach (var metric in metrics)
    {
        if (metric.Avg)
            selectors.Add($"{metric.MetricId}:avg");

        if (metric.Max)
            selectors.Add($"{metric.MetricId}:max");

        if (metric.Min)
            selectors.Add($"{metric.MetricId}:min");

        if (!metric.Avg &&
            !metric.Max &&
            !metric.Min)
        {
            selectors.Add(metric.MetricId);
        }
    }

    return string.Join(",", selectors);
}

public static Dictionary<string, JObject> BuildMetricLookup(JObject json)
{
    Dictionary<string, JObject> lookup =
        new Dictionary<string, JObject>(
            StringComparer.OrdinalIgnoreCase);

    JArray results =
        (JArray)json["result"];

    foreach (JObject result in results)
    {
        string metricId =
            result["metricId"].ToString();

        lookup[metricId] = result;
    }

    return lookup;
}

public static JObject GetMetricResult(
    Dictionary<string, JObject> metricLookup,
    string metricId,
    string aggregation)
{
    string key =
        string.IsNullOrWhiteSpace(aggregation)
        ? metricId
        : $"{metricId}:{aggregation}";

    if (metricLookup.ContainsKey(key))
        return metricLookup[key];

    return null;
}

public static Dictionary<string, JObject> BuildSeriesLookup(
    JObject metricResult)
{
    Dictionary<string, JObject> lookup =
        new Dictionary<string, JObject>(
            StringComparer.OrdinalIgnoreCase);

    if (metricResult == null)
        return lookup;

    JArray data =
        (JArray)metricResult["data"];

    foreach (JObject series in data)
    {
        string hostId =
            series["dimensions"][0].ToString();

        lookup[hostId] = series;
    }

    return lookup;
}

public static double? GetMetricValue(
    JObject series,
    int index)
{
    if (series == null)
        return null;

    JArray values =
        (JArray)series["values"];

    if (index >= values.Count)
        return null;

    return values[index]?.Value<double>();
}

public static DateTime GetTimestamp(
    JObject series,
    int index)
{
    JArray timestamps =
        (JArray)series["timestamps"];

    return DateTimeOffset
        .FromUnixTimeMilliseconds(
            timestamps[index].Value<long>())
        .UtcDateTime;
}
```

}

public class MetricConfig
{
public string MetricId { get; set; }

```
public bool Avg { get; set; }

public bool Max { get; set; }

public bool Min { get; set; }
```

}
