using System;
using System.Collections.Specialized;
using Microsoft.QualityTools.Testing.Fakes;
using Microsoft.VisualStudio.TestTools.UnitTesting;

using System.Configuration.Fakes;
using System.Messaging.Fakes;

[TestClass]
public class PerfDataQueueWriterTests
{
    private IDisposable _ctx;

    [TestInitialize]
    public void Init()
    {
        _ctx = ShimsContext.Create();

        // 🔴 CRITICAL: prevent static Logger crash
        System.Configuration.Fakes.ShimConfigurationManager.AppSettingsGet =
            () =>
            {
                return new NameValueCollection
                {
                    { "PerfDataQueue", "testQueue" },
                    { "LoggerServiceUri", "https://test.logger" },
                    { "OutputFile", @"c:\fake\" }
                };
            };

        // 🔴 CRITICAL: LoggerHelper MUST never return null
        LoggerHelper.Fakes.ShimLoggerHelper.GetConfigValueString =
            (key) =>
            {
                if (key == "LoggerServiceUri")
                    return "https://test.logger";

                return "test";
            };

        LoggerHelper.Fakes.ShimLoggerHelper.GetFarmType =
            () => "unit-test";

        LoggerHelper.Fakes.ShimLoggerHelper.SetConfigurationIConfiguration =
            (config) => { };

        // 🔴 CRITICAL: prevent MSMQ crash during static init
        System.Messaging.Fakes.ShimMessageQueue.ExistsString =
            (path) =>
            {
                if (string.IsNullOrEmpty(path))
                    return false;

                return false;
            };

        System.Messaging.Fakes.ShimMessageQueue.ConstructorString =
            (mq, path) => { };

        // 🔴 CRITICAL: neutralize logger calls
        Logger.Fakes.ShimLogger.AllInstances.LogInfoStringString =
            (l, a, b) => { };

        Logger.Fakes.ShimLogger.AllInstances.LogErrorStringException =
            (l, a, e) => { };

        Logger.Fakes.ShimLogger.AllInstances.LogDebugStringString =
            (l, a, b) => { };
    }

    [TestMethod]
    public void WriteToDatabase_QueueNotExists_ShouldNotThrow()
    {
        var writer = new Writer(); // ⚠ triggers static logger init

        writer.WriteToDatabase();

        Assert.IsTrue(true);
    }

    [TestCleanup]
    public void Cleanup()
    {
        _ctx?.Dispose();
    }
}
