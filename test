using System;
using System.Collections.Generic;
using System.Collections.Specialized;
using Microsoft.QualityTools.Testing.Fakes;
using Microsoft.VisualStudio.TestTools.UnitTesting;

using System.Configuration.Fakes;
using System.Messaging.Fakes;

// IMPORTANT: replace namespaces below with your actual ones
using YourProject.WriterNamespace;
using YourProject.LoggerNamespace;
using YourProject.HelpersNamespace;

[TestClass]
public class PerfDataQueueWriterTests
{
    private IDisposable _context;

    [TestInitialize]
    public void Setup()
    {
        _context = ShimsContext.Create();
    }

    [TestCleanup]
    public void Cleanup()
    {
        _context?.Dispose();
    }

    [TestMethod]
    public void WriteToDatabase_QueueDoesNotExist_ShouldNotThrow()
    {
        // -----------------------------
        // ARRANGE: AppSettings
        // -----------------------------
        ShimConfigurationManager.AppSettingsGet =
            () =>
            {
                var settings = new NameValueCollection
                {
                    { "PerfDataQueue", "testQueue" },
                    { "LoggerServiceUri", "https://test.logger" },
                    { "OutputFile", @"c:\fake\" }
                };

                return settings;
            };

        // -----------------------------
        // ARRANGE: LoggerHelper (VERY IMPORTANT)
        // prevents null ServiceUri inside Logger constructor
        // -----------------------------
        LoggerHelper.Fakes.ShimLoggerHelper.GetConfigValueString =
            (key) =>
            {
                if (key == "LoggerServiceUri")
                    return "https://test.logger";

                return "fake";
            };

        LoggerHelper.Fakes.ShimLoggerHelper.GetFarmType =
            () => "unit-test";

        LoggerHelper.Fakes.ShimLoggerHelper.SetConfigurationIConfiguration =
            (config) => { };

        // -----------------------------
        // ARRANGE: MSMQ does NOT exist
        // -----------------------------
        ShimMessageQueue.ExistsString =
            (path) =>
            {
                if (string.IsNullOrEmpty(path))
                    throw new Exception("QUEUE PATH IS NULL");

                return false;
            };

        // Prevent real MSMQ constructor call
        ShimMessageQueue.ConstructorString =
            (mq, path) => { };

        // -----------------------------
        // ARRANGE: Logger (kill all logging side effects)
        // IMPORTANT: match actual signature in your Logger class
        // -----------------------------
        Logger.Fakes.ShimLogger.AllInstances.LogInfoStringString =
            (logger, a, b) => { };

        Logger.Fakes.ShimLogger.AllInstances.LogErrorStringException =
            (logger, a, ex) => { };

        Logger.Fakes.ShimLogger.AllInstances.LogDebugStringString =
            (logger, a, b) => { };

        // -----------------------------
        // ARRANGE: Writer instance
        // -----------------------------
        var writer = new Writer();

        // -----------------------------
        // ACT + ASSERT
        // -----------------------------
        try
        {
            writer.WriteToDatabase();

            Assert.IsTrue(true, "Execution completed without exception.");
        }
        catch (Exception ex)
        {
            Assert.Fail($"Test failed with exception: {ex}");
        }
    }
}
